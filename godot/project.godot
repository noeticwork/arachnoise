; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

curved_lines_2d/add_stroke_enabled=false
curved_lines_2d/fill_color=Color(0.42745098, 0.32941177, 0.6627451, 1)

[application]

config/name="Arachnoise"
run/main_scene="uid://d08j3q33vb4l0"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
ChimePlayer="*uid://drxvp0xm37c8l"
MidiInputManager="*uid://slibxftlqvr5"
MidiMovementController="*uid://4ujadtb5h0oc"
MusicTheory="*uid://7yrbcqdbiid3"

[debug]

gdscript/warnings/native_method_override=1

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/size/mode=2

[editor_plugins]

enabled=PackedStringArray("res://addons/curved_lines_2d/plugin.cfg", "res://addons/godot_state_charts/plugin.cfg", "res://addons/inspector_tabs/plugin.cfg", "res://addons/midi_import/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/ropesim/plugin.cfg", "res://addons/simple_shadow_2d_1.0/addons/simple_shadow_2d/plugin.cfg")

